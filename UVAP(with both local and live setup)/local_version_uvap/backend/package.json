{
  "name": "uvap-backend-local",
  "version": "1.0.0",
  "description": "University Automation System Backend (Local)",
  "main": "server.js",
  "scripts": {
    "start": "concurrently \"npm run start:admin\" \"npm run start:faculty\" \"npm run start:student\" \"npm run start:notification\" \"npm run start:payment\"",
    "dev": "concurrently \"npm run dev:admin\" \"npm run dev:faculty\" \"npm run dev:student\" \"npm run dev:notification\" \"npm run dev:payment\"",
    "start:admin": "cd admin-service && node server.js",
    "start:faculty": "cd faculty-service && node server.js",
    "start:student": "cd student-service && node server.js",
    "start:notification": "cd notification-service && node server.js",
    "start:payment": "cd payment-service && node server.js",
    "dev:admin": "cd admin-service && nodemon server.js",
    "dev:faculty": "cd faculty-service && nodemon server.js",
    "dev:student": "cd student-service && nodemon server.js",
    "dev:notification": "cd notification-service && nodemon server.js",
    "dev:payment": "cd payment-service && nodemon server.js",
    "seed": "node seeder.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "colors": "^1.4.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-validator": "^6.14.3",
    "helmet": "^6.0.1",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^6.13.8",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^7.0.10"
  },
  "devDependencies": {
    "nodemon": "^2.0.20",
    "concurrently": "^8.2.2"
  }
}
